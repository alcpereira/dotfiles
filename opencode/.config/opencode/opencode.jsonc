{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/gpt-5-mini",
  "provider": {},
  "permission": {
    "bash": {
      "git add*": "ask",
      "git commit*": "ask",
      "git push*": "ask"
    }
  },
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/sse",
      "oauth": {},
      "enabled": false
    }
  }
}
